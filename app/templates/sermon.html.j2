<!doctype html>
<!-- sermon.html -->
<html lang="sv">
    <head>
        <meta charset="utf-8">
        <title>Predikoregister – Oskar Fornander</title>
        <style>
            /* Style for html page */
            {% include "sermon.css" %}
        </style>
    </head>
    <body>
        <header>

        </header>
        <main>

            <h1>Predikoregister – Oskar Fornander</h1>

            <table id="sermon">
                <thead>
                    <tr>
                        <th onclick="sortTable(0)">Kod</th>
                        <th onclick="sortTable(1)">Titel</th>
                        <th onclick="sortTable(2)">Datum</th>

                    </tr>
                </thead>
                <tbody>
                    {% for s in sermons %}
                    <tr>
                        <td>{{ s.code }}</td>
                        <td>{{ s.title }}</td>
                        <td>{{ s.date }}</td>

                    </tr>
                    {% endfor %}
                </tbody>
            </table>

        </main>
        <footer>
            <div>©Oskar Fornander 2026</div>
        </footer>
    </body>
</html>
