<!doctype html>
<!-- sermon.html -->
<html lang="sv">
    <head>
        <meta charset="utf-8">
        <title>Predikoregister – Oskar Fornander</title>
        <style>
            /* Style for html page */
            {% include "sermon.css" %}
        </style>
    </head>
    <body>
        <header>

        </header>
        <main>

            <h1>Predikoregister – Oskar Fornander</h1>

            <table id="sermon" data-sort-direction="DESC" data-sort-column="0">
                <thead>
                    <tr>
                        <th class="code" onclick="sortTable(0)">Kod</th>
                        <th class="title" onclick="sortTable(1)">Titel</th>
                        <th class="date" onclick="sortTable(2)">Datum</th>
                        <th class="all-dates hidden" onclick="sortTable(2)">Datum</th>

                    </tr>
                </thead>
                <tbody>
                    {% for s in sermons %}
                    <tr>
                        <td class="code">{{ s.code }}</td>
                        <td class="title">{{ s.title }}</td>
                        <td class="date">{{ s.date }}</td>
                        <td class="all-dates hidden">{{ ', '.join(s.all_dates) }}</td>

                    </tr>
                    {% endfor %}
                </tbody>
            </table>

        </main>
        <footer>
            <div>©Oskar Fornander 2026</div>
        </footer>
        <script type="text/javascript">
            {% include "sermon.js" %}
        </script>
    </body>
</html>
